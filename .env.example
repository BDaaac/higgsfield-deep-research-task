# Copy to .env and fill in your keys. Never commit .env.

# Required: Anthropic API key (used by both the agent and the judge)
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
DRL_MODEL=claude-haiku-4-5          # Agent model (default: claude-haiku-4-5)
DRL_SMALL_MODEL=claude-haiku-4-5    # Small model for extract_quotes tool
DRL_MAX_STEPS=12                     # Max agent loop iterations

# Eval framework settings
EVAL_JUDGE_MODEL=claude-haiku-4-5-20251001 # Judge model (active API model)
