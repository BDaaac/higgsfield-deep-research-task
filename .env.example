# Copy to .env and fill in your keys. Never commit .env.

# Required: Anthropic API key (used by both the agent and the judge)
ANTHROPIC_API_KEY=

# Agent configuration (do not change for reproducibility)
DRL_MODEL=claude-haiku-4-5          # Agent model under test
DRL_SMALL_MODEL=claude-haiku-4-5    # Small model for extract_quotes tool
DRL_MAX_STEPS=12                     # Max agent loop iterations

# Eval framework settings
# Judge uses Haiku 3.5 — cheaper than the agent ($0.80/$4 vs $1/$5 per MTok)
# and a different model generation, which mitigates self-preference bias.
EVAL_JUDGE_MODEL=claude-3-5-haiku-20241022
